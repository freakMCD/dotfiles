#!/usr/bin/env bash

set -u

# ── Configuration ────────────────────────────────────────────────────────────

readonly IFACE="enp34s0"
readonly NOTIF_ID=9999

# Time between renegotiation attempts while connected at 10 Mb/s.
readonly RETRY_DELAY=5

# Polling intervals for the different states.
readonly DOWN_POLL_DELAY=2
readonly UP_POLL_DELAY=5
readonly READ_RETRY_DELAY=1

readonly LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/network-renegotiate-${IFACE}.lock"

# ── Single-instance lock ─────────────────────────────────────────────────────

exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

# ── Functions ────────────────────────────────────────────────────────────────

get_carrier() {
    local carrier

    read -r carrier <"/sys/class/net/$IFACE/carrier" 2>/dev/null ||
        return 1

    [[ $carrier == 1 ]]
}

get_speed() {
    local speed

    read -r speed <"/sys/class/net/$IFACE/speed" 2>/dev/null ||
        return 1

    [[ $speed =~ ^[0-9]+$ ]] || return 1
    (( speed > 0 )) || return 1

    printf '%s\n' "$speed"
}

notify_disconnected() {
    notify-send \
        -r "$NOTIF_ID" \
        -t 2000 \
        "Network" \
        "Disconnected"
}

notify_renegotiating() {
    notify-send \
        -u critical \
        -t 0 \
        -r "$NOTIF_ID" \
        "Network Warning" \
        "Negotiated at 10 Mb/s. Renegotiating..."
}

notify_connected() {
    local speed=$1

    notify-send \
        -r "$NOTIF_ID" \
        -t 3000 \
        "Network" \
        "Connected at ${speed} Mb/s"
}

notify_failure() {
    notify-send \
        -u critical \
        -t 5000 \
        -r "$NOTIF_ID" \
        "Network Error" \
        "Failed to restart Ethernet autonegotiation."
}

# ── Validation ────────────────────────────────────────────────────────────────

if [[ ! -d /sys/class/net/$IFACE ]]; then
    printf 'Interface %s does not exist\n' "$IFACE" >&2
    exit 1
fi

if ! command -v flock >/dev/null; then
    printf 'Required command not found: flock\n' >&2
    exit 1
fi

if ! command -v ethtool >/dev/null; then
    printf 'Required command not found: ethtool\n' >&2
    exit 1
fi

if ! command -v notify-send >/dev/null; then
    printf 'Required command not found: notify-send\n' >&2
    exit 1
fi

# ── Main loop ────────────────────────────────────────────────────────────────

last_state=""

while true; do
    if ! get_carrier; then
        if [[ $last_state != down ]]; then
            notify_disconnected
            last_state="down"
        fi

        sleep "$DOWN_POLL_DELAY"
        continue
    fi

    speed=$(get_speed) || {
        sleep "$READ_RETRY_DELAY"
        continue
    }

    if (( speed == 10 )); then
        notify_renegotiating
        last_state="renegotiating"

        if ! sudo ethtool -r "$IFACE"; then
            notify_failure
            printf 'Failed to renegotiate interface %s\n' "$IFACE" >&2
        fi

        sleep "$RETRY_DELAY"
        continue
    fi

    if (( speed > 10 )); then
        if [[ $last_state != "up:$speed" ]]; then
            notify_connected "$speed"
            last_state="up:$speed"
        fi

        sleep "$UP_POLL_DELAY"
        continue
    fi

    # A positive but unexpected speed below 10 Mb/s.
    printf 'Unexpected speed reported for %s: %s Mb/s\n' \
        "$IFACE" "$speed" >&2

    sleep "$READ_RETRY_DELAY"
done
