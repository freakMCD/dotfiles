#!/usr/bin/env bash
set -u

music_dir="$HOME/Music"
cache_dir="$HOME/.cache/mpd-notify/covers"
mkdir -p "$cache_dir"

state="$(mpc status '%state%')"
[ "$state" = "playing" ] || exit 0

mapfile -t meta < <(mpc current --format $'%file%\n%artist%\n%title%\n%album%')

file_rel="${meta[0]:-}"
[ -n "$file_rel" ] || exit 0

file="$music_dir/$file_rel"
[ -f "$file" ] || exit 0

artist="${meta[1]:-}"
title="${meta[2]:-}"
album="${meta[3]:-}"

# Fallbacks if tags are missing
[ -z "$artist" ] && artist="Unknown Artist"
[ -z "$title" ] && title="${file_rel##*/}"

# Cache key: the file path itself. Can't rely on album tags matching
# shared art -- these are YouTube rips, so two tracks tagged with the
# same album can easily have different embedded thumbnails.
cache_key="$file_rel"
cache_hash="$(printf '%s' "$cache_key" | sha256sum | cut -d' ' -f1)"
cover="$cache_dir/${cache_hash}.png"

# Extract and cache art only if we haven't already got this track.
if [ ! -s "$cover" ] && [ ! -e "${cover}.none" ] && [ -f "$file" ]; then
    ffmpeg -loglevel error -y \
        -i "$file" \
        -map 0:v:0 \
        -an \
        -frames:v 1 \
        -vf "scale=500:500:force_original_aspect_ratio=increase,crop=500:500" \
        "$cover" 2>/dev/null

    if [ ! -s "$cover" ]; then
        rm -f "$cover"
        : > "${cover}.none"
    fi
fi

tmp_cover=""
if [ -s "$cover" ]; then
    tmp_cover="$cover"
fi

[ -z "$album" ] && album="Unknown Album"

# Truncate long strings with an ellipsis for consistent notification sizing
max_artist=25
max_title=50
max_album=25
truncate() {
    local s="$1" max="$2"
    if [ "${#s}" -gt "$max" ]; then
        printf '%s…' "${s:0:$((max - 1))}"
    else
        printf '%s' "$s"
    fi
}
artist="$(truncate "$artist" "$max_artist")"
title="$(truncate "$title" "$max_title")"
album="$(truncate "$album" "$max_album")"

icon_args=()
[ -n "$tmp_cover" ] && icon_args=(-i "$tmp_cover")

notify-send \
    -r 9998 \
    -t 6150 \
    "${icon_args[@]}" \
    "$title" \
    "$artist\n<i>$album</i>"
