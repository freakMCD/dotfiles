#!/usr/bin/env bash
set -u

music_dir="$HOME/Music"
cache_dir="$HOME/.cache/mpd-notify/covers"
mkdir -p "$cache_dir" || exit 1

[ "$(mpc status '%state%')" = "playing" ] || exit 0

mapfile -t meta < <(
    mpc --format $'%file%\n%artist%\n%title%\n%album%' current
)

file_rel="${meta[0]:-}"
file="$music_dir/$file_rel"
[ -n "$file_rel" ] && [ -f "$file" ] || exit 0

artist="${meta[1]:-Unknown Artist}"
title="${meta[2]:-${file_rel##*/}}"
album="${meta[3]:-Unknown Album}"

truncate() {
    local s="$1" max="$2"
    if ((${#s} > max)); then
        printf '%s…' "${s:0:$((max - 1))}"
    else
        printf '%s' "$s"
    fi
}

artist="$(truncate "$artist" 25)"
title="$(truncate "$title" 50)"
album="$(truncate "$album" 25)"

hash="$(printf '%s' "$file_rel" | sha256sum)"
cover="$cache_dir/${hash%% *}.png"
none="$cover.none"

if { [ ! -s "$cover" ] || [ "$file" -nt "$cover" ]; } &&
   { [ ! -e "$none" ] || [ "$file" -nt "$none" ]; }; then
    rm -f "$cover" "$none"

    if ! ffmpeg -nostdin -loglevel error -y \
        -i "$file" \
        -map 0:v:0 -an -frames:v 1 \
        -vf "scale=500:500:force_original_aspect_ratio=increase,crop=500:500" \
        "$cover" 2>/dev/null ||
       [ ! -s "$cover" ]; then
        rm -f "$cover"
        : > "$none"
    fi
fi

escape_body() {
    local s="$1"
    s=${s//\\/\\\\}
    s=${s//&/\&amp;}
    s=${s//</\&lt;}
    s=${s//>/\&gt;}
    printf '%s' "$s"
}

body="$(escape_body "$artist")"$'\n'"<i>$(escape_body "$album")</i>"

icon_args=()
[ -s "$cover" ] && icon_args=(-i "$cover")

notify-send \
    -r 9998 \
    -t 6150 \
    "${icon_args[@]}" \
    -- "$title" "$body"
