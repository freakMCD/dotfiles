{
    "layer": "top", // Waybar at top layer
    // "position": "top", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["mpd"],
    "modules-right": ["network", "custom/weather", "cpu", "temperature", "memory", "clock", "tray"],
    // Modules configuration
    "hyprland/workspaces": {
      "format": "<sub>{icon}</sub>",
	  "format-icons": {
		"1": "一",
		"2": "二",
		"3": "三",
		"4": "四",
		"5": "五",
		"6": "六",
		"7": "七",
		"8": "八",
		"9": "九"
	  },
      "ignore-workspaces": [
          "10",
          ],
    },

     "mpd": {
        "format": "<span color='#d3869b'>{stateIcon}  {artist} - {title}</span>",
        "format-disconnected": "Disconnected",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stoppep",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": " "
        },
        "state-icons": {
            "paused": "",
            "playing": ""
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },

    "custom/weather": {
        "format": "<span color='#d8a657'></span> {}",
        "format-alt": "{alt}: {}",
        "format-alt-click": "click-right",
        "interval": 1800,
        "exec": "curl \"wttr.in/?format=%t\"",
        "exec-if": "ping wttr.in -c1",
        "tooltip": false,
    },
   
    "cpu": {
        "format": "<span color='#d8a657'>CPU</span> {usage}%",
        "tooltip": false,
    },

    "temperature": {
        "thermal-zone": 0,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "<span color='red'>{temperatureC}°C</span>",
        "format": "{temperatureC}°C",
        "tooltip": false,
    },

    "memory": {
        "format": "<span color='#d8a657'>RAM</span> {}%",
		"tooltip-format": "{used:0.1f}/{total:0.1f}G",
    },

    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-ethernet": "<span color='#a9b665'> </span>",
        "tooltip-format": "{ifname} via {gwaddr} ",
        "format-disconnected": "󰈂",
    },

    "clock": {
        "timezones": [ "",
                       "Europe/Madrid"],
        "format": "{:<span color='#d8a657'>%a</span> %H:%M}",
        "tooltip-format": "{timezoned_time_list}\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode" : "month",
            "weeks-pos" : "right",
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },

    },

    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
}
